─── MachineVisual.cs ─────────────────────────────────────────────────────────
Attached to every machine prefab.

public int stationId
public Renderer bodyRenderer
public TextMeshPro label
public GameObject bottleneckArrow   // red arrow above machine
public Transform queueParent        // WIP boxes spawn here

Materials: matGreen, matAmber, matOrange, matRed, matGray

void UpdateStatus(float util, int queue, string status, bool isBottleneck):
    1. Set material:
         util < 0.70 → matGreen
         util < 0.85 → matAmber
         util < 0.95 → matOrange
         util ≥ 0.95 → matRed
         status == "broken" → matGray
    2. bottleneckArrow.SetActive(isBottleneck)
    3. If isBottleneck and not already pulsing: StartCoroutine(PulseArrow())
    4. Rebuild queue boxes: destroy old, spawn [queue] small cubes at
         queueParent.position + Vector3.right * i * 0.4f
    5. label.text = name + "\n" + (util*100).ToString("F0") + "% Q:" + queue
    6. label color = same tint as material

IEnumerator PulseArrow():
    while (isActiveAndEnabled):
        scale 1.0 → 1.5 → 1.0 using Mathf.SmoothStep over 0.8s
        yield return null

