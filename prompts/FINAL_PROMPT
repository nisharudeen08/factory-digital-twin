METHOD DrawConveyor(Vector3 from, Vector3 to):
  // Spawn conveyor prefab at midpoint between station centres
  // Scale X = distance - 1 unit (so it doesn't overlap boxes)
  Vector3 mid = (from + to) / 2f;
  float   len = Vector3.Distance(from, to);
  var obj = Instantiate(conveyorPrefab, mid, Quaternion.identity, factoryParent);
  obj.transform.LookAt(to);
  obj.transform.localScale = new Vector3(0.4f, 0.1f, len - 1.5f);

