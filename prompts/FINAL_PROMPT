fun buildFactoryConfig(): FactoryConfig {
    val stations = machineSpecs.value.mapIndexed { index, spec ->
        Station(
            id            = index + 1,
            name          = spec.nameEn,
            name_ta       = spec.nameTa,
            icon          = spec.machineId,        // e.g. "lathe", "weld", "qc"
            cycle_time_sec= spec.cycleTimeSec,
            num_machines  = spec.numMachines,      // THIS drives how many boxes Unity spawns
            mtbf_hours    = spec.mtbfHours,
            mttr_hours    = spec.mttrHours,
            setup_minutes = spec.setupMinutes,
            variability   = spec.variabilityFactor,// 0.08 / 0.15 / 0.25
            position_x    = index * 5f,            // stations spaced 5 metres apart
            position_z    = 0f,
            position_y    = 0f
        )
    }
    return FactoryConfig(
        factory_type  = selectedFactoryType.value,
        factory_name  = "My ${selectedFactoryType.value.capitalize()} Factory",
        mode          = "static",
        language      = settingsManager.getLanguage(),
        shift_hours   = 8f,
        num_operators = 2,
        stations      = stations
    )
}

