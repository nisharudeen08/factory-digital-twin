In api_server.py, complete the POST /config endpoint:

@app.post("/config")
async def save_config(config: FactoryConfigSchema):
    # 1. Validate
    errors = config_manager.validate_config(config.dict())
    if errors:
        return {"valid": False, "errors": errors}

    # 2. Save to disk
    config_path = "configs/factory_config.json"
    with open(config_path, "w") as f:
        json.dump(config.dict(), f, indent=2, ensure_ascii=False)

    # 3. Reload simulation engine with new config
    simulation_engine.reload_config(config.dict())

    # 4. Broadcast to Unity via WebSocket — IMMEDIATE rebuild trigger
    await unity_bridge.broadcast({
        "type": "config_update",
        "config": config.dict(),
        "message": "Factory config updated — rebuilding 3D scene"
    })

    return {
        "valid": True,
        "station_count": len(config.stations),
        "total_machines": sum(s.num_machines for s in config.stations),
        "message": f"Config saved: {len(config.stations)} stations, "
                   f"{sum(s.num_machines for s in config.stations)} total machines"
    }

