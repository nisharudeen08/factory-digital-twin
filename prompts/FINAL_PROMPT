  public SimulationManager simManager;

METHOD BuildFactory(string configJson = null):

  // 1. Clear ALL existing station GameObjects
  foreach (Transform child in factoryParent)
      Destroy(child.gameObject);
  simManager.ClearAllStations();

  // 2. Load config — from parameter (WebSocket) or file (startup)
  string json = configJson ?? File.ReadAllText(configPath);
  FactoryConfig cfg = JsonUtility.FromJson<FactoryConfig>(json);

  // 3. For each station, spawn num_machines boxes
  for (int i = 0; i < cfg.stations.Length; i++) {
      StationConfig s = cfg.stations[i];

      // Station anchor position (centre of all machines at this station)
      Vector3 stationPos = new Vector3(s.position_x, 0f, s.position_z);

      // ── SPAWN num_machines BOXES ──────────────────────────────────────
      // If num_machines == 1: spawn at stationPos directly
      // If num_machines >= 2: spread boxes along Z axis, centred on stationPos
      //   spacing = 1.8 units between boxes
      //   offset = (j - (num_machines-1)/2f) * 1.8f   on Z axis

      for (int j = 0; j < s.num_machines; j++) {
          float zOffset = s.num_machines > 1
              ? (j - (s.num_machines - 1) / 2f) * 1.8f
              : 0f;
          Vector3 boxPos = stationPos + new Vector3(0f, 0f, zOffset);

          GameObject box = Instantiate(stationBoxPrefab, boxPos,
                                       Quaternion.identity, factoryParent);
          box.name = $"S{s.id}_{s.icon}_M{j+1}";

          MachineVisual mv   = box.GetComponent<MachineVisual>();
          mv.stationId       = s.id;
          mv.machineIndex    = j;          // which machine in this station (0-based)
          mv.stationName     = s.name;
          mv.stationNameTa   = s.name_ta;
          mv.numMachinesTotal= s.num_machines;

          // Only show label on FIRST machine of each station
          mv.showLabel = (j == 0);

          // Register this box with SimulationManager
          // Multiple boxes at same station ALL respond to same station data
          simManager.RegisterMachine(s.id, j, mv);
      }

      // ── STATION COUNT LABEL ───────────────────────────────────────────
      // If num_machines > 1: spawn a small count badge above station centre
      // "× 2" floating text so worker knows there are 2 machines here
      if (s.num_machines > 1) {
          SpawnMachineCountLabel(stationPos, s.num_machines);
      }

      // ── CONVEYOR to next station ──────────────────────────────────────
      if (i < cfg.stations.Length - 1) {
          Vector3 nextPos = new Vector3(cfg.stations[i+1].position_x, 0f,
                                        cfg.stations[i+1].position_z);
          DrawConveyor(stationPos, nextPos);
      }
  }

  Debug.Log($"[Factory] Built: {cfg.stations.Length} stations, " +
            $"{cfg.stations.Sum(s => s.num_machines)} total machine boxes");

