Dictionary<int, List<MachineVisual>> stationMachines = new();

public void RegisterMachine(int stationId, int machineIndex, MachineVisual mv) {
    if (!stationMachines.ContainsKey(stationId))
        stationMachines[stationId] = new List<MachineVisual>();
    stationMachines[stationId].Add(mv);
}

public void ClearAllStations() {
    stationMachines.Clear();
}

In OnMessage handler, when updating station status:
// Python sends one status per STATION (not per machine)
// ALL machines at that station get the SAME color/status
// BUT queue is split: if queue=6 and num_machines=2,
//   show 3 queue boxes per machine (queue / num_machines, rounded up)

if (stationMachines.ContainsKey(stationData.id)) {
    var machines = stationMachines[stationData.id];
    int queuePerMachine = Mathf.CeilToInt(
        (float)stationData.queue / machines.Count);

    foreach (var mv in machines) {
        mv.UpdateStatus(
            stationData.util,
            queuePerMachine,       // split queue across machines
            stationData.status,
            stationData.is_bottleneck,
            currentLanguage
        );
    }
}

