write_file(
    absolutePath="C:/Users/nisharu deen/Downloads/PROJECT/factory_digital_twin/android/app/src/main/java/com/factory/digitaltwin/ui/unity/Unity3DFragment.kt",
    text="""package com.factory.digitaltwin.ui.unity

import android.graphics.Color
import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.FrameLayout
import androidx.fragment.app.Fragment
import androidx.lifecycle.lifecycleScope
import com.factory.digitaltwin.R
import com.factory.digitaltwin.data.local.SettingsManager
import com.factory.digitaltwin.databinding.FragmentUnity3dBinding
import com.factory.digitaltwin.network.FactoryWebSocket
import com.factory.digitaltwin.network.RetrofitClient
import com.unity3d.player.UnityPlayerForGameActivity
import kotlinx.coroutines.flow.collectLatest
import kotlinx.coroutines.flow.first
import kotlinx.coroutines.launch
import java.net.URI

class Unity3DFragment : Fragment() {

    private var _binding: FragmentUnity3dBinding? = null
    private val binding get() = _binding!!

    private var webSocket: FactoryWebSocket? = null
    private lateinit var settingsManager: SettingsManager
    
    // Unity player instance for GameActivity
    private var unityPlayer: UnityPlayerForGameActivity? = null

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        _binding = FragmentUnity3dBinding.inflate(inflater, container, false)
        return binding.root
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)
        settingsManager = SettingsManager(requireContext())

        // Initialize Unity using the GameActivity pattern
        val activity = requireActivity()
        val surfaceView = UnityPlayerForGameActivity.createSurfaceView(activity)
        
        unityPlayer = UnityPlayerForGameActivity(activity, binding.unityContainer, surfaceView, null)
        
        // Add Unity player view to our container
        binding.unityContainer.addView(
            surfaceView,
            FrameLayout.LayoutParams(
                FrameLayout.LayoutParams.MATCH_PARENT,
                FrameLayout.LayoutParams.MATCH_PARENT
            )
        )
        
        surfaceView.requestFocus()
        unityPlayer?.windowFocusChanged(true)

        viewLifecycleOwner.lifecycleScope.launch {
            val baseUrl = settingsManager.serverIpFlow.first()
            RetrofitClient.updateBaseUrl(baseUrl)
            connectWebSocket(baseUrl)
        }
    }

    private fun connectWebSocket(baseUrl: String) {
        val wsUrl = toWebSocketUrl(baseUrl)
        webSocket?.close()
        webSocket = FactoryWebSocket(URI(wsUrl)).also { socket ->
            socket.connect()

            viewLifecycleOwner.lifecycleScope.launch {
                socket.connectedFlow.collectLatest { connected ->
                    binding.statusDot.setBackgroundColor(
                        Color.parseColor(if (connected) "#22C55E" else "#EF4444")
                    )
                }
            }

            viewLifecycleOwner.lifecycleScope.launch {
                socket.stateFlow.collectLatest { state ->
                    if (state == null) {
                        return@collectLatest
                    }

                    binding.shiftProgress.progress = (state.shiftPct * 100).toInt()
                    binding.shiftLabel.text = getString(
                        R.string.shift_progress_value,
                        (state.shiftPct * 100).toInt()
                    )
                }
            }
        }
    }

    private fun toWebSocketUrl(baseUrl: String): String {
        val normalized = if (baseUrl.startsWith("http://") || baseUrl.startsWith("https://")) {
            baseUrl
        } else {
            "http://$baseUrl"
        }

        return normalized
            .replaceFirst("http://", "ws://")
            .replaceFirst("https://", "wss://")
            .replace(":8000", ":8765")
            .let { if (it.endsWith("/")) it.dropLast(1) else it }
    }

    override fun onResume() {
        super.onResume()
        unityPlayer?.onResume()
    }

    override fun onPause() {
        super.onPause()
        unityPlayer?.onPause()
    }

    override fun onDestroyView() {
        super.onDestroyView()
        // Use destroy() for UnityPlayerForGameActivity
        unityPlayer?.destroy()
        unityPlayer = null
        
        webSocket?.close()
        webSocket = null
        _binding = null
    }
}
"""
)