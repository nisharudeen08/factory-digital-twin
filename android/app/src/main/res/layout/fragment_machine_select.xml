<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
 xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:orientation="vertical"
 android:background="@color/background_light">
<!-- Hero Toolbar -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_gradient_toolbar"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="48dp"
    android:paddingBottom="24dp">

    <!-- Step indicator row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <!-- Step 1 active pill -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="STEP 1"
            android:textColor="@color/primary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"
            android:layout_marginEnd="8dp"/>

        <View
            android:layout_width="24dp"
            android:layout_height="1dp"
            android:background="#7C3AED"
            android:alpha="0.5"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 2"
            android:textColor="#A78BFA"
            android:textSize="9sp"
            android:letterSpacing="0.12"
            android:layout_marginEnd="8dp"/>

        <View
            android:layout_width="24dp"
            android:layout_height="1dp"
            android:background="#7C3AED"
            android:alpha="0.5"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 3"
            android:textColor="#A78BFA"
            android:textSize="9sp"
            android:letterSpacing="0.12"/>

    </LinearLayout>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Your\nMachines"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="bold"
        android:lineSpacingMultiplier="1.1"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="இயந்திரங்களை தேர்வு செய்யவும்"
        android:textColor="#C4B5FD"
        android:textSize="11sp"/>

</LinearLayout>

<!-- Thin progress bar -->
<ProgressBar
    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
    android:layout_width="match_parent"
    android:layout_height="4dp"
    android:progress="33"
    android:progressTint="@color/primary"
    android:progressBackgroundTint="#E9D5FF"/>

<!-- Instruction banner -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/primary_100"
    android:orientation="horizontal"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💡"
        android:textSize="14sp"
        android:layout_marginEnd="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap + to add machines. Leave at 0 to skip."
        android:textColor="@color/primary"
        android:textSize="12sp"
        android:textStyle="bold"/>

</LinearLayout>

<!-- Machine list -->
<ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="8dp"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- LATHE MACHINE -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- Icon box -->
                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_circle_light"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙️"
                        android:textSize="24sp"/>

                </LinearLayout>

                <!-- Name block -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lathe Machine"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="தட்டு இயந்திரம்"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:layout_marginTop="1dp"/>

                </LinearLayout>

                <!-- Stepper -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/background_light"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/btn_lathe_minus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_minus"
                        android:src="@drawable/ic_remove_24"
                        android:padding="8dp"
                        android:contentDescription="minus"/>

                    <TextView
                        android:id="@+id/tv_lathe_count"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <ImageView
                        android:id="@+id/btn_lathe_plus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_plus"
                        android:src="@drawable/ic_add_24"
                        android:padding="8dp"
                        android:contentDescription="plus"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- CNC MILLING -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_circle_light"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔧"
                        android:textSize="24sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CNC Milling"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="சி.என்.சி. மில்லிங்"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:layout_marginTop="1dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/background_light"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/btn_cnc_minus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_minus"
                        android:src="@drawable/ic_remove_24"
                        android:padding="8dp"
                        android:contentDescription="minus"/>

                    <TextView
                        android:id="@+id/tv_cnc_count"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <ImageView
                        android:id="@+id/btn_cnc_plus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_plus"
                        android:src="@drawable/ic_add_24"
                        android:padding="8dp"
                        android:contentDescription="plus"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- DRILL PRESS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_circle_light"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔩"
                        android:textSize="24sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Drill Press"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="துளையிடும் இயந்திரம்"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:layout_marginTop="1dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/background_light"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/btn_drill_minus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_minus"
                        android:src="@drawable/ic_remove_24"
                        android:padding="8dp"
                        android:contentDescription="minus"/>

                    <TextView
                        android:id="@+id/tv_drill_count"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <ImageView
                        android:id="@+id/btn_drill_plus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_plus"
                        android:src="@drawable/ic_add_24"
                        android:padding="8dp"
                        android:contentDescription="plus"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- WELDING STATION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@color/chipRedBg"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="24sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welding Station"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="வெல்டிங் நிலையம்"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:layout_marginTop="1dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/background_light"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/btn_weld_minus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_minus"
                        android:src="@drawable/ic_remove_24"
                        android:padding="8dp"
                        android:contentDescription="minus"/>

                    <TextView
                        android:id="@+id/tv_weld_count"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <ImageView
                        android:id="@+id/btn_weld_plus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_plus"
                        android:src="@drawable/ic_add_24"
                        android:padding="8dp"
                        android:contentDescription="plus"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- SURFACE GRINDER -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@color/chipAmberBg"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡"
                        android:textSize="24sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Surface Grinder"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="அரைக்கும் இயந்திரம்"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:layout_marginTop="1dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/background_light"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/btn_grind_minus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_minus"
                        android:src="@drawable/ic_remove_24"
                        android:padding="8dp"
                        android:contentDescription="minus"/>

                    <TextView
                        android:id="@+id/tv_grind_count"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <ImageView
                        android:id="@+id/btn_grind_plus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_plus"
                        android:src="@drawable/ic_add_24"
                        android:padding="8dp"
                        android:contentDescription="plus"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- BAND SAW -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@color/chipGreenBg"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🪚"
                        android:textSize="24sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Band Saw"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="பேண்ட் சா"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:layout_marginTop="1dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/background_light"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/btn_bandsaw_minus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_minus"
                        android:src="@drawable/ic_remove_24"
                        android:padding="8dp"
                        android:contentDescription="minus"/>

                    <TextView
                        android:id="@+id/tv_bandsaw_count"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <ImageView
                        android:id="@+id/btn_bandsaw_plus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_plus"
                        android:src="@drawable/ic_add_24"
                        android:padding="8dp"
                        android:contentDescription="plus"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- QC INSPECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@color/chipBlueBg"
                    android:gravity="center"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔍"
                        android:textSize="24sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="QC Inspection"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="தர சரிபார்ப்பு"
                        android:textColor="@color/primary"
                        android:textSize="11sp"
                        android:layout_marginTop="1dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/background_light"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <ImageView
                        android:id="@+id/btn_qc_minus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_minus"
                        android:src="@drawable/ic_remove_24"
                        android:padding="8dp"
                        android:contentDescription="minus"/>

                    <TextView
                        android:id="@+id/tv_qc_count"
                        android:layout_width="44dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <ImageView
                        android:id="@+id/btn_qc_plus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_stepper_plus"
                        android:src="@drawable/ic_add_24"
                        android:padding="8dp"
                        android:contentDescription="plus"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>

<!-- Footer -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="24dp"
    android:elevation="12dp">

    <!-- Summary row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SELECTED"
                android:textColor="@color/text_hint"
                android:textSize="9sp"
                android:letterSpacing="0.12"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_total_machines"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 machines"
                android:textColor="@color/primary"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Machine type count badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_selected"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Step 1 of 3"
            android:textColor="@color/primary"
            android:textSize="11sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Next button -->
    <Button
        android:id="@+id/btn_next_to_params"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_gradient_purple_card"
        android:text="Next: Set Parameters →"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.02"
        android:stateListAnimator="@null"/>

</LinearLayout>
</LinearLayout>
