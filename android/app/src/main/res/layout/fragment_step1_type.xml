<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Gradient Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_toolbar"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back_24"
                android:contentDescription="Back"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/setup_step1_title"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Setup · Step 1 of 3"
                android:textColor="@color/primary_100"
                android:textSize="9sp"/>

        </LinearLayout>

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Step Progress Dots -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp"
                android:layout_marginTop="8dp">

                <!-- Step 1 dot — active -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_step_dot_active"
                        android:text="1"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Type"
                        android:textColor="@color/primary"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- Line between 1 and 2 -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/primary"
                    android:layout_marginBottom="14dp"/>

                <!-- Step 2 dot — next -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_step_dot_future"
                        android:text="2"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Machines"
                        android:textColor="@color/text_secondary"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- Line between 2 and 3 -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="14dp"/>

                <!-- Step 3 dot — future -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_step_dot_future"
                        android:text="3"
                        android:textColor="@color/step_future"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Specs"
                        android:textColor="@color/text_hint"
                        android:textSize="10sp"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Section label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_factory_type"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <!-- Factory Type 2x2 Grid -->
            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Lathe Card — selected by default -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_lathe"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/surface_white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Colored top -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:background="@color/primary_100"/>

                        <!-- Emoji label on top area -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:text="⚙️"
                            android:textSize="28sp"
                            android:gravity="center"
                            android:layout_marginTop="-70dp"/>

                        <!-- Card bottom text -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/factory_lathe"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/factory_lathe_sub"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Textile Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_textile"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/surface_white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:background="#FDF2F8"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:text="🧵"
                            android:textSize="28sp"
                            android:gravity="center"
                            android:layout_marginTop="-70dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/factory_textile"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/factory_textile_sub"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Food Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_food"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/surface_white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:background="@color/warning_bg"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:text="🍪"
                            android:textSize="28sp"
                            android:gravity="center"
                            android:layout_marginTop="-70dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/factory_food"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/factory_food_sub"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Electronics Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_electronics"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/surface_white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:background="@color/info_bg"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:text="💡"
                            android:textSize="28sp"
                            android:gravity="center"
                            android:layout_marginTop="-70dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/factory_electronics"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/factory_electronics_sub"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp"/>

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Number of Stations Card -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/number_of_stations"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <!-- Minus button -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btn_stations_minus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardBackgroundColor=
                                "@color/primary_100"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_remove_24"
                                android:padding="12dp"
                                android:contentDescription="Minus"/>

                        </androidx.cardview.widget.CardView>

                        <!-- Station count -->
                        <TextView
                            android:id="@+id/tv_station_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="4"
                            android:textColor="@color/text_primary"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:gravity="center"/>

                        <!-- Plus button -->
                        <androidx.cardview.widget.CardView
                            android:id="@+id/btn_stations_plus"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardBackgroundColor=
                                "@color/primary_100"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_add_24"
                                android:padding="12dp"
                                android:contentDescription="Plus"/>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/stations_hint"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp"
                        android:gravity="center"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- Next Button footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background_light"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_next"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_gradient"
            android:text="@string/btn_next"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>
