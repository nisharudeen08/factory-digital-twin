<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
 xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:orientation="vertical"
 android:background="@color/background_light">
<!-- Hero Toolbar -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_gradient_toolbar"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="48dp"
    android:paddingBottom="24dp">

    <!-- Step indicator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 1"
            android:textColor="#A78BFA"
            android:textSize="9sp"
            android:letterSpacing="0.12"
            android:layout_marginEnd="8dp"/>

        <View
            android:layout_width="24dp"
            android:layout_height="1dp"
            android:background="@color/white"
            android:alpha="0.4"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEP 2"
            android:textColor="#A78BFA"
            android:textSize="9sp"
            android:letterSpacing="0.12"
            android:layout_marginEnd="8dp"/>

        <View
            android:layout_width="24dp"
            android:layout_height="1dp"
            android:background="@color/white"
            android:alpha="0.4"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="STEP 3"
            android:textColor="@color/primary"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.12"/>

    </LinearLayout>

    <!-- Title row with LIVE badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Simulation\nSetup"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.1"/>

        </LinearLayout>

        <!-- Ready badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#1A2D1B"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/bg_step_dot_done"
                android:layout_marginEnd="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="READY"
                android:textColor="#4ADE80"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

<!-- Thin progress -->
<ProgressBar
    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
    android:layout_width="match_parent"
    android:layout_height="4dp"
    android:progress="100"
    android:progressTint="@color/primary"
    android:progressBackgroundTint="#E9D5FF"/>

<!-- Scrollable content -->
<ScrollView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_weight="1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- CONTROL MATRIX label -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:background="@color/primary"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONTROL MATRIX"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"/>

        </LinearLayout>

        <!-- Production Goal card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_light"
                        android:text="🏭"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Production Goal"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_demand_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="200"
                        android:textColor="@color/primary"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" units"
                        android:textColor="@color/text_hint"
                        android:textSize="12sp"/>

                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chip_demand_100"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="100"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/chip_demand_150"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="150"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/chip_demand_200"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_gradient_purple_card"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="200"
                            android:textColor="@color/white"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/chip_demand_250"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="250"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginEnd="8dp"/>

                        <TextView
                            android:id="@+id/chip_demand_300"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_chip_unselected"
                            android:paddingStart="18dp"
                            android:paddingEnd="18dp"
                            android:text="300"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:gravity="center"/>

                    </LinearLayout>

                </HorizontalScrollView>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Workers card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_light"
                        android:text="👷"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Workers on Shift"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_workers_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2"
                        android:textColor="@color/success"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_workers_1"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:text="1"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/chip_workers_2"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_gradient_purple_card"
                        android:text="2"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/chip_workers_3"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:text="3"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/chip_workers_4"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:text="4"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Shift Length card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_light"
                        android:text="⏱️"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Shift Length"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tv_shift_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8h"
                        android:textColor="@color/text_secondary"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chip_shift_6h"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:text="6h"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/chip_shift_8h"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_gradient_purple_card"
                        android:text="8h"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/chip_shift_10h"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:text="10h"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/chip_shift_12h"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:text="12h"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Machine Condition card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="@color/surface_white"
            app:cardCornerRadius="20dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_light"
                        android:text="🔧"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Machine Condition"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/btn_condition_good"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:text="✓ Good"
                        android:textColor="@color/success"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/btn_condition_average"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_gradient_purple_card"
                        android:text="~ Average"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:id="@+id/btn_condition_poor"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_chip_unselected"
                        android:text="✗ Poor"
                        android:textColor="@color/danger"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>

<!-- Execute button footer -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="24dp"
    android:elevation="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SimPy engine ready"
            android:textColor="@color/success"
            android:textSize="11sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sync: 100%"
            android:textColor="@color/text_hint"
            android:textSize="11sp"/>

    </LinearLayout>

    <!-- Preview in 3D before simulating -->
    <Button
        android:id="@+id/btn_preview_3d"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/bg_card_outline"
        android:text="🏭  Preview Factory in 3D"
        android:textColor="@color/primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:stateListAnimator="@null"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btn_execute_simulation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/bg_gradient_purple_card"
        android:text="▶  Execute Simulation"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.04"
        android:stateListAnimator="@null"/>

    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:indeterminateTint="@color/primary"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Running SimPy simulation..."
            android:textColor="@color/text_secondary"
            android:textSize="12sp"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tv_projected_output"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="—"/>

</LinearLayout>
</LinearLayout>
