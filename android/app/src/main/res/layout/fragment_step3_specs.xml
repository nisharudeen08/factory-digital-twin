<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Gradient Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_gradient_toolbar"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_back_24"
                android:contentDescription="Back"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_step3_title"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_step_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Setup · Step 3 · Machine 1 of 4"
                    android:textColor="@color/primary_100"
                    android:textSize="9sp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Progress dots row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="@color/surface_white">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_step_dot_active"/>

        <View
            android:layout_width="32dp"
            android:layout_height="2dp"
            android:background="@color/primary"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_step_dot_active"/>

        <View
            android:layout_width="32dp"
            android:layout_height="2dp"
            android:background="@color/primary"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_step_dot_active"/>

    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Machine Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <!-- Purple left border -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/primary"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <!-- Emoji box -->
                        <TextView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@color/primary_100"
                            android:text="⚙️"
                            android:textSize="24sp"
                            android:gravity="center"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_machine_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lathe Machine"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:id="@+id/tv_machine_name_ta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="தட்டு இயந்திரம் · Station 1"
                                android:textColor="@color/primary"
                                android:textSize="10sp"
                                android:layout_marginTop="2dp"/>

                            <!-- Badges row -->
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="8dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background=
                                        "@drawable/bg_chip_selected"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp"
                                    android:text="Lathe / CNC"
                                    android:textColor="@color/primary"
                                    android:textSize="10sp"
                                    android:textStyle="bold"
                                    android:layout_marginEnd="6dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background=
                                        "@drawable/bg_status_success"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp"
                                    android:text="@string/required"
                                    android:textColor="@color/success"
                                    android:textSize="10sp"
                                    android:textStyle="bold"/>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Parameters Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Row 1: Cycle Time -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/cycle_time"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/cycle_time_sub"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_input_pill"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/et_cycle_time"
                                android:layout_width="60dp"
                                android:layout_height="wrap_content"
                                android:text="45"
                                android:textColor="@color/primary"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:background="@null"
                                android:inputType="number"
                                android:gravity="center"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unit_sec"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="16dp"/>

                    <!-- Row 2: Number of Machines -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/num_machines"
                                android:textColor="@color/text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/num_machines_sub"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp"/>

                        </LinearLayout>

                        <!-- Machine count stepper -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/btn_machines_minus"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@color/primary_100"
                                android:src="@drawable/ic_remove_24"
                                android:padding="6dp"
                                android:contentDescription="Minus"/>

                            <TextView
                                android:id="@+id/tv_machines_count"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:text="2"
                                android:textColor="@color/primary"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:gravity="center"/>

                            <ImageView
                                android:id="@+id/btn_machines_plus"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@color/primary_100"
                                android:src="@drawable/ic_add_24"
                                android:padding="6dp"
                                android:contentDescription="Plus"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="16dp"/>

                    <!-- Row 3: Variability chips -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/variability"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/variability_sub"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp"
                            android:layout_marginBottom="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/chip_variability_low"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:background=
                                    "@drawable/bg_chip_selected"
                                android:text="Low"
                                android:textColor="@color/primary"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:id="@+id/chip_variability_medium"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:background=
                                    "@drawable/bg_chip_unselected"
                                android:text="Medium"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:gravity="center"
                                android:layout_marginEnd="6dp"/>

                            <TextView
                                android:id="@+id/chip_variability_high"
                                android:layout_width="0dp"
                                android:layout_height="36dp"
                                android:layout_weight="1"
                                android:background=
                                    "@drawable/bg_chip_unselected"
                                android:text="High"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:gravity="center"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="16dp"/>

                    <!-- Row 4: MTBF + MTTR side by side -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- MTBF -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor=
                                "@color/background_light"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/mtbf"
                                    android:textColor="@color/text_hint"
                                    android:textSize="10sp"
                                    android:textStyle="bold"/>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="bottom">

                                    <EditText
                                        android:id="@+id/et_mtbf"
                                        android:layout_width="50dp"
                                        android:layout_height="wrap_content"
                                        android:text="8.0"
                                        android:textColor="@color/text_primary"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:background="@null"
                                        android:inputType="numberDecimal"
                                        android:gravity="center"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/unit_hrs"
                                        android:textColor="@color/text_hint"
                                        android:textSize="11sp"/>

                                </LinearLayout>

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                        <!-- MTTR -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardBackgroundColor=
                                "@color/background_light"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/mttr"
                                    android:textColor="@color/text_hint"
                                    android:textSize="10sp"
                                    android:textStyle="bold"/>

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="bottom">

                                    <EditText
                                        android:id="@+id/et_mttr"
                                        android:layout_width="50dp"
                                        android:layout_height="wrap_content"
                                        android:text="0.5"
                                        android:textColor="@color/text_primary"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:background="@null"
                                        android:inputType="numberDecimal"
                                        android:gravity="center"/>

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/unit_hrs"
                                        android:textColor="@color/text_hint"
                                        android:textSize="11sp"/>

                                </LinearLayout>

                            </LinearLayout>

                        </androidx.cardview.widget.CardView>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- Prev / Dots / Next navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_white"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/btn_previous"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@color/chip_bg_unselected"
            android:text="@string/btn_previous"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:stateListAnimator="@null"/>

        <!-- Dot indicators -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <View
                android:id="@+id/dot_1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_step_dot_active"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/dot_2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_step_dot_future"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/dot_3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_step_dot_future"
                android:layout_marginEnd="4dp"/>

            <View
                android:id="@+id/dot_4"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_step_dot_future"/>

        </LinearLayout>

        <Button
            android:id="@+id/btn_next"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_button_gradient"
            android:text="@string/btn_next"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>
